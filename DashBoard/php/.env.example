# ============================================
# Configuration Email - TEMPLATE (.env.example)
# ============================================
# Renommez ce fichier en '.env' et remplissez les valeurs réelles

# Mode environnement : 'development' ou 'production'
MAIL_ENV=development

# ============================================
# Configuration Gmail (pour les TESTS)
# ============================================
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_SMTP_SECURITY=tls
GMAIL_FROM_EMAIL=votre.email@gmail.com
GMAIL_FROM_NAME=Support Tickets PFO
GMAIL_USERNAME=votre.email@gmail.com
GMAIL_PASSWORD=mot_de_passe_app_gmail

# ============================================
# Configuration Exchange Hosteam (PRODUCTION)
# ============================================
EXCHANGE_SMTP_HOST=webmail19.hosteam.fr
EXCHANGE_SMTP_PORT=587
EXCHANGE_SMTP_SECURITY=tls
EXCHANGE_FROM_EMAIL=serviceinfo@pfo-construction.com
EXCHANGE_FROM_NAME=Service Info PFO Construction
EXCHANGE_USERNAME=serviceinfo@pfo-construction.com
EXCHANGE_PASSWORD=mot_de_passe_exchange

# ============================================
# URL de base de l'application
# ============================================
APP_URL=http://localhost/Ticket

# ============================================
# Autres paramètres email
# ============================================
MAIL_REPLY_TO=serviceinfo@pfo-construction.com

# ============================================
# Configuration Base de données
# ============================================
DB_HOST=localhost
DB_NAME=tickets_bd
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4
